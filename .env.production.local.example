# copy to .env.production.local and fill in values (gitignored)
#
# docker compose: docker compose --env-file .env.production.local up --build
# swarm: make swarm-secrets-prepare then make swarm-up / swarm-deploy-stack

PORT=3000
NODE_ENV=production
HOSTNAME=0.0.0.0

DB_HOST=localhost
DB_PORT=5432
DB_USER=bia_app
DB_PASSWORD=change-me
DB_NAME=bia_prod

JWT_SECRET=change-me
JWT_EXPIRE=1d
JWT_COOKIE_EXPIRE=30

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ARCJET_KEY=
ARCJET_ENV=production

TAVILY_API_KEY=

# pgadmin (local compose only)
PGADMIN_DEFAULT_EMAIL=you@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
