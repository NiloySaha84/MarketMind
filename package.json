{
  "name": "MarketMind",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
    "test:integration": "NODE_ENV=test node --test --test-concurrency=1 tests/integration",
    "test:db:up": "docker compose -f tests/docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f tests/docker-compose.test.yml down -v",
    "test:all": "npm test && npm run test:db:up && npm run test:integration",
    "start": "node app.js",
    "dev": "nodemon app.js",
    "start:api": "node app.js",
    "start:dispatcher": "node dispatcher-server.js",
    "start:worker": "node worker-server.js",
    "dev:api": "nodemon app.js",
    "dev:dispatcher": "nodemon dispatcher-server.js",
    "dev:worker": "nodemon worker-server.js"
  },
  "dependencies": {
    "@arcjet/inspect": "^1.4.0",
    "@arcjet/node": "^1.4.0",
    "apminsight": "^5.4.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.2",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^17.4.2",
    "express": "~4.16.1",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1",
    "openai": "^6.39.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
