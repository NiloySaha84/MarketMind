# --- Local dev (npm run dev) ---
# Where the Vite dev server proxies /api requests (your backend API).
VITE_API_PROXY_TARGET=http://localhost:3000

# Optional: override the API base path the app calls. Defaults to "/api/v1"
# (relative), which works behind both the Vite dev proxy and the nginx prod proxy.
# Only set this if you want the browser to call the API directly (requires CORS
# on the backend).
# VITE_API_BASE_URL=/api/v1

# --- Docker / production (consumed by nginx at container start) ---
# The backend service URL the nginx container proxies /api to.
# In docker-compose this is typically the API service name, e.g. http://api:3000
API_UPSTREAM=https://your-api-public-domain
